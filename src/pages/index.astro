---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from "astro:assets";
import HeroImage from "../assets/Hero.png";
import '../styles/global.css';
---

<MainLayout>
    <section class="hero-wrapper">
        <div class="banner"></div>
            <div class="banner-credit">Credit: <a href="https://svs.gsfc.nasa.gov/13510/#media_group_321209" target="_blank" rel="noopener noreferrer">NASA's Goddard Space Flight Center/Chris Smith (USRA)</a>
            </div>
        <Image src={HeroImage} class="image-container" alt="Placeholder" loading="eager" />
        </section>

    <section class="content">
        <div class="card-grid">
            <div class="card">
                <h2>Welcome to My Portfolio</h2>
                <p>Explore my projects and learn more about me.</p>
            </div>
            <div class="card">
                <h2>Projects</h2>
                <p>Check out my latest work and contributions.</p>
            </div>
            <div class="card">
                <h2>About Me</h2>
                <p>Learn more about my background and skills.</p>
            </div>
        </div>
    </section>

    <style>
        .hero {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-top: 4rem;
        }

        .hero-wrapper {
            background-color: var(--color-background);
            margin: 0;
            padding: 0;
            position: relative; /* Ensure the wrapper is the reference point */
        }

        .banner {
            position: relative; /* Make the banner the reference point for positioning */
            display: block;
            width: 90%; /* Ensure the banner spans the full width */
            height: 400px; /* Fixed height for consistency */
            background-image: url('/src/assets/Wolftopia_Banner.png');
            background-size: cover; /* Ensure the image covers the banner */
            background-position: center;
            background-repeat: no-repeat;
            z-index: 1;
            margin: 0 auto; /* Center the banner */
        }

        .image-container {
            position: absolute; /* Position relative to the banner */
            top: 50%; /* Center vertically */
            left: 50%; /* Center horizontally */
            transform: translate(-50%, -50%); /* Adjust for the image's own dimensions */
            z-index: 2; /* Ensure it appears above the banner */
            display: flex;
            justify-content: center;
            align-items: center;
            border: 2px var(--color-accent-primary) dashed;
            width: 160px; /* Match the size of the image */
            height: 160px; /* Match the size of the image */
        }

        .hero-image {
            width: 160px; /* Set a fixed width */
            height: 160px; /* Match height to width to make it square */
            object-fit: cover; /* Crop the image to fit the square */
            object-position: center; /* Center the cropped area */
            box-shadow: 0 6px 18px var(--color-box-shadow-soft); /* Soft shadow for depth */
            background: var(--color-card-background);
            background-origin: 50%;
        }

        .banner-credit {
            position: absolute;
            margin-left: 3rem;
            margin-top: .5rem;
            font-size: 0.95rem;
            color: var(--color-text-secondary);
            text-decoration: none;
            background: rgba(var(--color-background), 0.1); /* Subtle dark background */
            box-shadow: 0 2px 8px var(--color-box-shadow);
            max-width: 90vw;
            z-index: 3;
            text-align: left;
        }

        .banner-credit a {
            color: var(--color-accent-primary);
            text-decoration: underline;
            transition: color .5s, text-decoration-thickness .5s;
        }
        .banner-credit a:hover {
            color: var(--color-text-link-hover);
            text-decoration-thickness: 2px;
        }

        .content {
            padding: 2rem; /* Add padding for space */
            margin: 0 auto; /* Center the content */
            width: 90%; /* Set a max width */
            background-color: var(--color-footer-background); /* Optional: Different background color */
            color: var(--color-text-main); /* Optional: Text color */
            text-align: center; /* Center the text */
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr); /* Two equal columns */
            gap: 1rem; /* Add spacing between the cards */
            padding: 1rem; /* Optional: Add padding around the grid */
            justify-content: center; /* Center the grid */
            justify-items: center; /* Center the cards in the grid */
        }

        .card {
            background: var(--color-card-background); /* Var background for the card */
            width: 50%;
            border-radius: 8px; /* Rounded corners for a card-like feel */
            box-shadow: 0 4px 8px var(--color-box-shadow-soft); /* Subtle shadow for depth */
            padding: 1.5rem; /* Add padding inside the card */
            text-align: left; /* Align text to the left */
            color: var(--color-text-main); /* Dark text color */
            transition: transform 0.3s, box-shadow 0.3s; /* Smooth hover effect */
        }

        .card:hover {
            transform: translateY(-5px); /* Slight lift on hover */
            box-shadow: 0 6px 12px var(--color-box-shadow-hard); /* Stronger shadow on hover */
        }

        @media (max-width: 640px) { 
            .hero-image {
                grid-template-columns: 1fr; /* Switch to a single column on smaller screens */
                width: 120px; /* Adjust size for smaller screens */
                height: 120px; /* Keep it square */
            }
        }
    </style>
</MainLayout>