---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from "astro:assets";
import HeroImage from "../assets/Hero.png";
import '../styles/global.css';
---

<MainLayout>
    <section class="hero-wrapper">
        <div class="banner"></div>
            <div class="banner-credit"><b>Credit</b>: <a href="https://svs.gsfc.nasa.gov/13510/#media_group_321209" target="_blank" rel="noopener noreferrer">NASA's Goddard Space Flight Center/Chris Smith (USRA)</a>
            </div>
        <Image src={HeroImage} class="image-container" alt="Placeholder" loading="eager" />
        </section>

    <section class="content">
        <div class="card-grid">
            <div class="card">
                <h2>Placeholder</h2>
                <p>&nbsp&nbsp&nbsp&nbspSample Text</p>
            </div>
            <div class="card">
                <h2>Placeholder</h2>
                <p>&nbsp&nbsp&nbsp&nbspSample Text</p>
            </div>
            <div class="card">
                <h2>Placeholder</h2>
                <p>&nbsp&nbsp&nbsp&nbspSample Text</p>
            </div>
            <div class="card">
                <h2>Placeholder</h2>
                <p>&nbsp&nbsp&nbsp&nbspSample Text</p>
            </div>
        </div>
    </section>

    <style>
    .hero {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-top: 4rem;
    }

    .hero-wrapper {
        background-color: var(--color-background);
        margin: 0;
        padding: 0;
        position: relative; /* Ensure the wrapper is the reference point */
    }

    .banner {
        position: relative;
        display: block;
        width: 90%;
        height: 400px;
        box-shadow: -4px 0 12px var(--color-box-shadow-soft), 4px 0 12px var(--color-box-shadow-soft), 0 6px 16px var(--color-box-shadow-hard); /* Softer and more balanced shadow */
        background-image: url('/src/assets/Wolftopia_Banner.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 1;
        margin: 0 auto;
        border-radius: 10px; /* Subtle rounding for a modern look */
    }

    .image-container {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2;
        display: flex;
        justify-content: center;
        align-items: center;
        border: 3px var(--color-accent-primary) solid; /* Solid border for emphasis */
        box-shadow: 0 4px 12px var(--color-box-shadow-hard); /* Stronger shadow for focus */
        width: 160px;
        height: 160px;
        border-radius: 8px; /* Keep square shape with slightly rounded corners */
        background: var(--color-card-background); /* Add a background for contrast */
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        border-radius: 8px; /* Match the container's slightly rounded corners */
    }

    .banner-credit {
        position: absolute;
        margin-left: 3rem;
        margin-top: 0.5rem;
        font-size: 0.95rem;
        color: var(--color-text-secondary);
        text-decoration: none;
        max-width: 90vw;
        z-index: 3;
        text-align: left;
    }

    .banner-credit a {
        color: var(--color-accent-primary);
        text-decoration: underline;
        transition: color 0.3s ease, text-decoration-thickness 0.3s ease;
    }

    .banner-credit a:hover {
        color: var(--color-text-link-hover);
        text-decoration-thickness: 2px;
    }

    .content {
        padding: 2rem;
        margin: 2rem auto; /* Add spacing above and below */
        width: 90%;
        max-width: 1200px; /* Limit the width for better readability */
        box-shadow: -4px 0 12px var(--color-box-shadow-soft), 4px 0 12px var(--color-box-shadow-soft), 0 6px 16px var(--color-box-shadow-hard); /* Improved shadow */
        background-color: var(--color-footer-background);
        color: var(--color-text-main);
        text-align: center;
        border-radius: 12px; /* Add rounding for a polished look */
    }

    .card-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr); /* Two equal columns */
        gap: 1rem; /* Add spacing between the cards */
        padding: 1rem; /* Optional: Add padding around the grid */
        justify-content: center; /* Center the grid */
        justify-items: center; /* Center the cards in the grid */
    }
    
    .card {
        background: var(--color-card-background);
        width: 75%;
        border-radius: 12px;
        box-shadow: 0 4px 12px var(--color-box-shadow-soft); /* Subtle shadow for depth */
        padding: 1.5rem;
        text-align: left;
        color: var(--color-text-main);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
        transform: translateY(-8px); /* Slight lift on hover */
        box-shadow: 0 8px 16px var(--color-box-shadow-hard); /* Stronger shadow on hover */
    }

    @media (max-width: 640px) {
        .hero-image {
            width: 120px;
            height: 120px;
        }

        .card-grid {
            grid-template-columns: 1fr; /* Single column on smaller screens */
        }
    }
</style>
</MainLayout>